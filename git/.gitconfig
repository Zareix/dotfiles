[user]
	email = raphcatarino@gmail.com
	name = Raphaël Catarino
[core]
  excludesFile = ~/.mygitignore
	ignorecase = false
[init]
  defaultBranch = main
[pull]
  rebase = false
[gpg]
  program = gpg
	format = openpgp
[commit]
  gpgSign = false
[tag]
  forceSignAnnotated = false
[gpg "ssh"]
	program = ssh-keygen
[credential]
  helper = store
